{
  "name": "mongoose-unique-validator",
  "version": "6.1.0",
  "type": "module",
  "description": "mongoose-unique-validator is a plugin which adds pre-save validation for unique fields within a Mongoose schema.",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "scripts": {
    "test": "mocha",
    "test:docker": "docker compose up -d --wait && pnpm run test && docker compose down",
    "test:docker:mongoose8": "node scripts/test-mongoose8.js",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,css,cjs,mjs,ts}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "keywords": [
    "mongoose",
    "unique",
    "validator"
  ],
  "author": {
    "name": "Mike Botsko",
    "email": "botsko@gmail.com"
  },
  "contributors": [
    {
      "name": "Blake Haswell",
      "email": "haswell00@gmail.com",
      "url": "http://blakehaswell.com/"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mongoose-unique-validator/mongoose-unique-validator.git"
  },
  "bugs": {
    "url": "https://github.com/mongoose-unique-validator/mongoose-unique-validator/issues"
  },
  "homepage": "https://github.com/mongoose-unique-validator/mongoose-unique-validator#readme",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "chai": "^6.2.2",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "mocha": "^11.7.5",
    "mongoose": "^9.2.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "peerDependencies": {
    "mongoose": "^8.0.0 || ^9.0.0"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "package.json",
    "LICENSE.txt",
    "README.md"
  ]
}
